# cluster-bootstrap — installs apl-core on the LKE-E cluster and seeds the
# GitOps repo credentials. Applied AFTER the `cluster` workspace; it reads the
# kubeconfig from the cluster workspace's remote state output.
#
#   terraform workspace select <env>      # must match the cluster workspace
#   terraform apply -var-file=<env>.tfvars
#
# Copy this file to <env>.tfvars (lab | staging | primary | secondary | <your-env>)
# and fill the ADOPTER-MUST-SET values. SECRETs come from TF_VAR_* env vars in
# CI — never put them in a committed tfvars file.

# Deployment discriminator — must match the cluster workspace's backend key
# suffix and the apl-values/<env> overlay directory name.
# MIGRATION NOTE: this key was previously named `region` (it never held a
# Linode region). Instances upgrading the template must rename `region` to
# `deployment` in their cluster-bootstrap *.tfvars; CI supplies it as
# TF_VAR_deployment.
deployment = "your-env"

# apl-core Helm chart — pin a version and bump deliberately.
# Verify with: helm search repo apl/apl --versions
apl_chart_version = "5.0.0"

# Subdirectory under apl-values/ for this cluster's overlay.
apl_values_env = "your-env"

# NOTE: the base DNS domain (cluster.domainSuffix), the logical cluster.name,
# the Loki/Harbor S3 bucket labels + endpoint, and the values-repo branch are
# NOT cluster-bootstrap tfvars — `llz render` writes them straight into the
# committed values.yaml from the spec, and `llz ci resolve-harbor-url` derives
# harbor.<domainSuffix> from the spec too.

# GitOps repo holding apl-values/ and manifest/ — apl-core's external values
# store (the in-cluster Gitea is obsoleted). apl-core REQUIRES an HTTPS URL on a
# publicly-reachable host. This points at the instance repo itself; apl-operator
# reads AND writes its rendered values tree here over HTTPS with the PAT below,
# so the PAT needs Contents: write. `<@ instance_repo @>` is rendered to the
# instance's owner/name at instantiation. `llz render` also writes otomi.git.repoUrl
# into values.yaml from the spec; this tfvar additionally feeds the Argo CD
# values-repo credential Secret.
apl_values_repo_url = "https://github.com/<@ instance_repo @>.git"
# GitHub ignores the basic-auth username when a PAT is the password; the
# conventional token sentinel is fine.
apl_values_repo_username = "x-access-token"

# Branch/tag/commit of the first-party bootstrap repo (your fork of your-org/your-instance-repo)
# that the TF-managed bootstrap Argo CD Application tracks.
apps_repo_revision = "main"

# ── SECRETs — supply via TF_VAR_* env vars in CI, NOT in this file ────────────
#   TF_VAR_tf_state_bucket             S3 bucket holding the cluster workspace state
#   TF_VAR_linode_dns_token            Linode token scoped to DNS zone write
#   TF_VAR_apl_values_repo_token       GitHub fine-grained PAT (Contents: write) for the values + apps repo
#   TF_VAR_loki_admin_password         Loki gateway basic-auth admin password (optional — generated + persisted if empty)
