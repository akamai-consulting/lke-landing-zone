# openbao-config — configures an already-running OpenBao (KV v2 engine, AppRole
# + Kubernetes auth, policies). Run once per cluster after OpenBao is unsealed.
#
# Unlike the other roots this has no per-env tfvars in-repo — the in-repo
# deployment uses the module defaults and supplies connection details via
# TF_VAR_* at runtime. Copy to terraform.tfvars only for a local run.

# OpenBao API address. From a local port-forward use https://localhost:8200;
# from inside the cluster use the in-cluster service address.
openbao_address = "https://localhost:8200"

# Set true ONLY when connecting via port-forward (SNI won't match the internal
# CA). Leave false in-cluster.
openbao_skip_tls_verify = true

# Path to a CA cert for TLS verification. Leave empty with skip_tls_verify=true
# or when using system CAs.
# openbao_ca_cert_file = ""

# Kubernetes API server URL for OpenBao's Kubernetes auth method — the
# in-cluster address visible from OpenBao pods. Default is usually correct.
# kubernetes_host = "https://kubernetes.default.svc:443"

# ── SECRET — supply via TF_VAR_* env var, NOT in this file ────────────────────
#   TF_VAR_openbao_token   root/admin token (mint with `bao operator generate-root`;
#                          revoke after apply)
