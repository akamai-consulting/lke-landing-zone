# LandingZone spec — starting template. Copy to `landingzone.yaml`, fill in the
# instance identity + your environments (one environments/<env>.yaml each), and
# `llz render` reconciles it into the per-env tfvars terraform consumes.
# See docs/landing-zone-spec.md.
apiVersion: llz.akamai-consulting.io/v1alpha1
kind: LandingZone
metadata:
  name: REPLACE_INSTANCE_NAME            # instance name (repo short name)
spec:
  instance:
    upstreamOrg: REPLACE_UPSTREAM_ORG    # template source org
    repo: REPLACE_OWNER/REPLACE_REPO     # <owner>/<name>
    forge: github                        # github | github-enterprise | gitlab
    templateVersion: REPLACE_LLZ_VERSION # pinned llz release, or "main"

  # ── DNS / cert (optional) ──────────────────────────────────────────────────
  # Instance-wide cert-manager DNS-01 issuer config. Set acmeEmail to render the
  # Let's Encrypt registration contact into every env's overlay from the spec
  # (else it stays a REPLACE_PER_ENV placeholder you fill by hand).
  dns:
    acmeEmail: ops@example.com

  # ── Shared VPCs (optional — most instances omit this) ──────────────────────
  # By default every env gets its OWN DEDICATED VPC (its own state, fully isolated)
  # — the safest posture. Declare a shared VPC only to CO-LOCATE 2+ clusters in ONE
  # region (e.g. prod-web + prod-api). A Linode VPC is region-scoped, so a network
  # is too: name them <tier>-<region>, one per region. Each shared VPC is its own
  # Terraform state (vpc/<network>), isolated from every other.
  #
  # KEEP PROD ISOLATED: prod and non-prod always get SEPARATE networks — never let a
  # non-prod env attach to a prod network, or a non-prod build's VPC apply runs
  # against prod's state. An env must be in its network's region (the validator
  # rejects cross-region attach).
  #
  # MULTI-REGION PROD: a prod HA pair with ONE cluster per region needs NO shared
  # network — each cluster is alone in its region, so a dedicated VPC is correct and
  # most isolated. You only need prod-<region> networks when you co-locate SEVERAL
  # prod clusters in a region. The example below shows that case (prod in two
  # regions, each its own VPC) — trim it to what you actually run.
  networks:
    prod-ord:    { region: us-ord } # prod, region 1 (e.g. HA primary)
    prod-sea:    { region: us-sea } # prod, region 2 (e.g. HA secondary)
    nonprod-ord: { region: us-ord } # dev/staging/lab co-located in us-ord

  # ── Shared defaults (optional) ─────────────────────────────────────────────
  # Inherited by every environment; a per-env value overrides field-by-field.
  defaults:
    cluster:
      k8sVersion: v1.33.6+lke7
      nodePool: { type: g8-dedicated-8-4, count: 5 }
    # apl-core global feature flags (otomi.*), rendered into every env's
    # values.yaml by `llz render`. Both optional — shown with their defaults.
    platform:
      externalDNS: true    # otomi.hasExternalDNS — external-dns manages records
      externalIDP: false   # otomi.hasExternalIDP — false → standalone Keycloak

# Then author one environments/<env>.yaml per deployment (cluster definition +
# component toggles + per-component sizing). See the fully-commented
# environments/prod-web-ord.yaml.example for the complete per-env surface — it
# shows a co-located cluster attaching to the prod-ord network above. A lone
# per-region cluster just omits cluster.network.vpc and gets its own dedicated VPC.
