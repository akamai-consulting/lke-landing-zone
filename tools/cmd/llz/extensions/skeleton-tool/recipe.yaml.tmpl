# <@ .Name @> — scaffolded by `llz extension new --kind tool`.
#
# Thin extension: it only shells to an already-tested external tool, so it has no
# logic of its own to unit-test — `llz extension lint` requires no tests for
# kind:tool (the tool is the tested unit, upstream). Keep it argv-only.
schemaVersion: 2
name: <@ .Name @>
short: TODO one-line description (wraps the <@ .Tool @> tool)
kind: tool
tools: [<@ .Tool @>]
check:
  - name: <@ .Name @>
    argv: [<@ .Tool @>, --version]
